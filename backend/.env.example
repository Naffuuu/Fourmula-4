# --- App ---
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-long-random-string
ROLL_NUMBER_PEPPER=change-me-to-a-different-long-random-string

# --- JWT ---
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Database ---
# docker-compose sets this for you automatically inside the containers;
# override if running the backend outside docker against local mysql.
DATABASE_URL=mysql+aiomysql://akp_user:akp_password@localhost:3306/anti_kuddus_protocol

# --- CORS ---
# Comma-separated list. Never use "*" once cookies/credentials are involved.
CORS_ORIGINS=http://localhost:5173

# --- Google OAuth ---
# Google Cloud Console → Credentials → OAuth 2.0 Client ID (Web application)
GOOGLE_CLIENT_ID=

# --- Facebook Login ---
# Meta for Developers → your app → Settings → Basic
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# --- LLM provider (Mission 3 + Mission 6 embeddings) ---
# Leave blank to fall back to the local TF-IDF baseline for fact-checking and
# a simple extractive summarizer for the syllabus negotiator.
LLM_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- File storage ---
STORAGE_BACKEND=local
UPLOADS_DIR=/app/uploads
# only used if STORAGE_BACKEND=s3
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Rate limiting ---
LOGIN_RATE_LIMIT=5/minute
