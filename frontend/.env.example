# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
# Authorized JavaScript origin: http://localhost:5173
VITE_GOOGLE_CLIENT_ID=

# Meta for Developers → your app → Settings → Basic → App ID
# App domain: localhost ; Facebook Login product enabled, valid OAuth redirect not required
# for the JS-SDK popup flow used here, but add http://localhost:5173 anyway for safety.
VITE_FACEBOOK_APP_ID=

# Only needed if you run vite dev against a backend on a non-default host/port
VITE_API_PROXY_TARGET=http://localhost:8000
VITE_WS_PROXY_TARGET=ws://localhost:8000
